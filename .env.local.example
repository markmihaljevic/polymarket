# ------- Required -------

# The Odds API key — get one at https://the-odds-api.com/
# Pinnacle lines are accessed through this service.
ODDS_API_KEY=your_odds_api_key_here

# Shared secret used by Vercel Cron to authenticate /api/cron/refresh.
# Any random string. Vercel adds `Authorization: Bearer <CRON_SECRET>` automatically
# when it invokes the cron. Generate one with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# ------- Upstash Redis (install via Vercel Marketplace -> Storage -> Redis) -------
# These are auto-populated when you link an Upstash Redis store to the project;
# only needed locally if you want `npm run dev` to read/write the shared cache.
# The app accepts either KV_* (legacy Vercel KV names) or UPSTASH_REDIS_* names.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ------- Optional tuning -------

# Minimum edge (as a decimal, e.g. 0.02 = 2%) for a row to appear on the page.
# Anything tighter than ~1.5% is usually noise given matching/timing slippage.
NEXT_PUBLIC_MIN_EDGE=0.02

# Comma-separated Odds API sport_keys to force-include. Leave blank to auto-detect
# from /sports. Example: soccer_epl,basketball_nba,americanfootball_nfl
ODDS_API_SPORTS_OVERRIDE=
